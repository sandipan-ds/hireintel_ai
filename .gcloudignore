# ===========================================================================
# .gcloudignore — files excluded from the Cloud Build source upload
# ===========================================================================
# This file mirrors .dockerignore so that the gcloud builds submit context
# upload is as small as possible (target: <50 MiB).
# ===========================================================================

.git/
.gitignore
.gcloudignore
.dockerignore
.venv/
.vscode/
.opencode/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.history/
.checkpoints/
AGENTS.md

# Data — exclude raw/processed resumes (privacy + size) but KEEP pre-computed
# ranked score files so the My Project Ranking tab works in production.
data/original/
data/processed/
data/embeddings/
data/job_descriptions/
data/candidate_registry.json
data/scoring_progress.json
recruiter/data/original/
recruiter/data/processed/
recruiter/data/embeddings/
recruiter/data/job_descriptions/
recruiter/data/candidate_registry.json
recruiter/data/scoring_progress.json
# Exclude per-candidate score subdirs (large) but keep role-level ranked JSONs
data/scores/composed/BusinessAnalyst/
data/scores/composed/DataScience/
data/scores/composed/JavaDeveloper/
data/scores/composed/ReactDeveloper/
data/scores/composed/SQLDeveloper/
data/scores/composed/SalesManager/
data/scores/composed/SrPythonDeveloper/
data/scores/composed/WebDesigning/

# Local model weights — no longer needed (DEC-036: Gemini API embedding)
recruiter/models/

# Experiment tracking & run artifacts
mlruns/
reports/
run_reports/
scratch/
scratch_diag.py

# Developer-only
notebooks/
tests/
baseline/
graphify-out/
recruiter/src/graphify-out/

# Logs
logs/
recruiter/logs/
*.log

