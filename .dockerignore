# ===========================================================================
# .dockerignore — files excluded from the Docker build context
# ===========================================================================
# This file controls what gets sent to the Cloud Build daemon.
# Smaller context = faster uploads (target: <50 MiB).
# ===========================================================================

# ---------------------------------------------------------------------------
# Python runtime artifacts
# ---------------------------------------------------------------------------
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# VCS & IDE
# ---------------------------------------------------------------------------
.git/
.gitignore
.history/
.vscode/
.opencode/

# ---------------------------------------------------------------------------
# CI / dev config
# ---------------------------------------------------------------------------
.gcloudignore
.dockerignore
.checkpoints/
AGENTS.md

# ---------------------------------------------------------------------------
# Data — exclude raw/processed resumes (privacy + size) but KEEP pre-computed
# ranked score files so the My Project Ranking tab works in production.
data/original/
data/processed/
data/embeddings/
data/job_descriptions/
data/candidate_registry.json
data/scoring_progress.json
recruiter/data/original/
recruiter/data/processed/
recruiter/data/embeddings/
recruiter/data/job_descriptions/
recruiter/data/candidate_registry.json
recruiter/data/scoring_progress.json
# Exclude per-candidate score subdirs (large) but keep role-level ranked JSONs
data/scores/composed/BusinessAnalyst/
data/scores/composed/DataScience/
data/scores/composed/JavaDeveloper/
data/scores/composed/ReactDeveloper/
data/scores/composed/SQLDeveloper/
data/scores/composed/SalesManager/
data/scores/composed/SrPythonDeveloper/
data/scores/composed/WebDesigning/

# ---------------------------------------------------------------------------
# Local ML model weights — baking is replaced by Gemini API (DEC-036)
# ---------------------------------------------------------------------------
recruiter/models/

# ---------------------------------------------------------------------------
# Experiment tracking & evaluation artifacts
# ---------------------------------------------------------------------------
mlruns/
reports/
run_reports/
scratch/
scratch_diag.py

# ---------------------------------------------------------------------------
# Developer-only directories (not on serving path)
# ---------------------------------------------------------------------------
notebooks/
tests/
baseline/
graphify-out/
recruiter/src/graphify-out/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
recruiter/logs/
*.log

# ---------------------------------------------------------------------------
# Secrets — never ever copy env files into the image
# ---------------------------------------------------------------------------
.env
.env.*

# ---------------------------------------------------------------------------
# Documentation — not needed at serve time
# ---------------------------------------------------------------------------
docs/

# ---------------------------------------------------------------------------
# Legacy doc files (old names)
# ---------------------------------------------------------------------------
GCP_DEPLOYMENT_GUIDE.md
gcp_deployment_plan.md
task.md
GCP_Deployment_Details.md
